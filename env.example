# ══════════════════════════════════════════════════════════════
#  SIAA — Sistema Inteligente de Apoyo Administrativo v2.1.27
#  .env.example — Plantilla de configuración
#
#  INSTRUCCIONES:
#    1. Copie este archivo:  cp .env.example .env
#    2. Edite los valores según su instalación
#    3. NUNCA suba el .env real al repositorio
#
#  Rama Judicial · Seccional Bucaramanga
# ══════════════════════════════════════════════════════════════


# ── Red ─────────────────────────────────────────────────────────
# IP del servidor accesible desde los navegadores de los despachos
# Ejemplo: 192.168.1.100  (dejar vacío = detectar automáticamente)
SIAA_SERVER_IP=

# Puerto expuesto al navegador
# 80  → si Nginx hace el proxy (producción recomendada)
# 5000 → si se accede directo al Flask (desarrollo)
SIAA_SERVER_PORT=5000


# ── Ollama / Modelo LLM ─────────────────────────────────────────
# URL interna de Ollama (no cambiar salvo instalación especial)
OLLAMA_URL=http://localhost:11434

# Modelo a usar. Opciones probadas:
#   qwen2.5:3b   → 15s/consulta ✅ RECOMENDADO
#   deepseek-r1:8b → 90s/consulta ❌ muy lento
#   qwen3:8b     → 6+ min ❌ descartado
SIAA_MODEL=qwen2.5:3b


# ── Rutas del sistema ───────────────────────────────────────────
# Carpeta con los documentos .md indexados
SIAA_CARPETA_FUENTES=/opt/siaa/fuentes

# Archivo de log de calidad (formato JSONL)
SIAA_LOG_ARCHIVO=/opt/siaa/logs/calidad.jsonl


# ── Rendimiento del servidor ────────────────────────────────────
# Consultas simultáneas a Ollama (no superar núcleos físicos / 2)
SIAA_MAX_OLLAMA_SIMULTANEOS=2

# Hilos del servidor Waitress (para 26 despachos, 16 es suficiente)
SIAA_HILOS_SERVIDOR=16

# Timeouts en segundos
SIAA_TIMEOUT_CONEXION=8
SIAA_TIMEOUT_RESPUESTA=180


# ── Caché LRU ───────────────────────────────────────────────────
# Máximo de respuestas en caché (200 cubre preguntas frecuentes de 26 despachos)
SIAA_CACHE_MAX_ENTRADAS=200

# Tiempo de vida de cada entrada en segundos (3600 = 1 hora)
SIAA_CACHE_TTL_SEGUNDOS=3600


# ── RAG — Extracción de fragmentos ─────────────────────────────
# Tamaño de cada chunk en caracteres
# 800 → balance velocidad/contexto recomendado para qwen2.5:3b
# 1200 → más contexto pero +5s por consulta
SIAA_CHUNK_SIZE=800

# Solapamiento entre chunks (evita que artículos queden partidos)
SIAA_CHUNK_OVERLAP=300

# Máximo de chunks por documento enviados al modelo
SIAA_MAX_CHUNKS_CONTEXTO=3

# Máximo de documentos considerados por consulta
SIAA_MAX_DOCS_CONTEXTO=2


# ── RAG — Índice de keywords ────────────────────────────────────
# Top N keywords por documento para el enrutador TF-IDF
SIAA_TOP_KEYWORDS_POR_DOC=20

# Frecuencia mínima para considerar una keyword (1 = todas)
SIAA_MIN_FREQ_KEYWORD=1

# Longitud mínima de keyword en caracteres
SIAA_MIN_LEN_KEYWORD=3


# ── Log ─────────────────────────────────────────────────────────
# Máximo de líneas antes de rotar el log (~2MB por 5000 entradas)
SIAA_LOG_MAX_LINEAS=5000
