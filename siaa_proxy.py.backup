# ── System prompt compacto ───────────────────────────────────────
SYSTEM_BASE = """Eres SIAA, asistente judicial Seccional Bucaramanga.
Identifica mentalmente el tipo de despacho o proceso antes de responder.
Responde SOLO lo preguntado. Máximo 3 líneas.
PROHIBIDO: explicaciones, introducciones, conclusiones."""

# ================================================================
#  MONITOR OLLAMA
# ================================================================

ollama_estado = {"disponible": False, "ultimo_check": 0, "fallos": 0}
ollama_lock   = threading.Lock()

def verificar_ollama() -> bool:
    try:
        r = requests.get(f"{OLLAMA_URL}/api/tags", timeout=TIMEOUT_HEALTH)
        ok = r.status_code == 200
    except:
        ok = False
    with ollama_lock:
        ollama_estado["disponible"] = ok
        ollama_estado["ultimo_check"] = time.time()
        ollama_estado["fallos"] = 0 if ok else ollama_estado["fallos"] + 1
    return ok

def monitor_ollama():
    while True:
        verificar_ollama()
        time.sleep(10)

threading.Thread(target=monitor_ollama, daemon=True).start()

# ================================================================
#  SEMÁFORO Y CONTADORES
# ================================================================

ollama_semaforo  = threading.Semaphore(MAX_OLLAMA_SIMULTANEOS)
usuarios_activos = 0
total_atendidos  = 0
contadores_lock  = threading.Lock()

def inc_activos():
    global usuarios_activos, total_atendidos
    with contadores_lock:
        usuarios_activos += 1
        total_atendidos  += 1

def dec_activos():
    global usuarios_activos
    with contadores_lock:
        usuarios_activos = max(0, usuarios_activos - 1)

# ================================================================
#  DOCUMENTOS
# ================================================================

documentos_cargados = {}
documentos_lock     = threading.Lock()

def cargar_documentos():
    global documentos_cargados
    nuevos = {}
    if not os.path.exists(CARPETA_FUENTES):
        os.makedirs(CARPETA_FUENTES, exist_ok=True)
        return
    archivos = (glob.glob(os.path.join(CARPETA_FUENTES, "*.md")) +
                glob.glob(os.path.join(CARPETA_FUENTES, "*.txt")))
    for ruta in archivos:
        try:
            nombre = os.path.basename(ruta).lower()
            with open(ruta, "r", encoding="utf-8", errors="ignore") as f:
                contenido = f.read()
            palabras = set(re.findall(r'\b[a-záéíóúüñ]{4,}\b', contenido.lower()))
            nuevos[nombre] = {"ruta": ruta, "contenido": contenido,
                              "palabras_clave": palabras, "tamano": len(contenido)}
            print(f"  [Doc] {nombre} ({len(contenido):,} chars)")
        except Exception as e:
            print(f"  [Doc] Error {ruta}: {e}")
    with documentos_lock:
        documentos_cargados = nuevos
    print(f"  [Doc] Total: {len(nuevos)} documentos")

# ================================================================
#  ENRUTADOR — 2 niveles
# ================================================================

def detectar_fuentes(pregunta: str) -> dict:
    p   = pregunta.lower()
    res = {"bases_de_datos": [], "documentos": []}

    # Bases de datos
    for nombre_bd, config in BASES_DE_DATOS.items():
        if any(kw in p for kw in config["palabras_clave"]):
            res["bases_de_datos"].append(nombre_bd)

    # Nivel 1: palabras clave explícitas
    encontrados = []
    for nombre_doc, keywords in DOCUMENTOS_PALABRAS_CLAVE.items():
        if nombre_doc in documentos_cargados and any(kw in p for kw in keywords):
            encontrados.append(nombre_doc)

    if encontrados:
        if len(encontrados) > 2:
            scored = []
            for nombre in encontrados:
                kws   = DOCUMENTOS_PALABRAS_CLAVE[nombre]
                score = sum(1 for kw in kws if kw in p)
                scored.append((score, nombre))
            scored.sort(reverse=True)
            res["documentos"] = [n for _, n in scored[:2]]
        else:
            res["documentos"] = encontrados
    else:
        # Nivel 2: fallback automático
        palabras = set(re.findall(r'\b[a-záéíóúüñ]{4,}\b', p))
        with documentos_lock:
            docs = dict(documentos_cargados)
        scored = []
        for nombre, doc in docs.items():
            score = len(palabras & doc["palabras_clave"])
            if score >= 2:
                scored.append((score, nombre))
        scored.sort(reverse=True)
        res["documentos"] = [n for _, n in scored[:2]]

    return res

# ================================================================
#  SQL — formato texto plano (ahorra tokens vs tablas Markdown)
# ================================================================

def generar_consultas_sql(pregunta: str, nombre_bd: str) -> list:
    p = pregunta.lower()
    consultas = []
    if nombre_bd == "casos_2025":

        if any(w in p for w in ["total","cuántos","cuantos","hay","registros","casos"]):
            consultas.append(("Total por tipo",
                "SELECT tipo_caso, COUNT(*) as total FROM año2025 GROUP BY tipo_caso ORDER BY total DESC"))

        municipios = {
            "bucaramanga":"Bucaramanga","barrancabermeja":"Barrancabermeja",
            "san gil":"San Gil","socorro":"Socorro","floridablanca":"Floridablanca",
            "girón":"Girón","giron":"Girón","piedecuesta":"Piedecuesta",
            "vélez":"Vélez","velez":"Vélez","málaga":"Málaga","malaga":"Málaga",
        }
        for kw, nombre in municipios.items():
            if kw in p:
                tipo = ("AND tipo_caso='Incidentes'" if "incidente" in p else
                        "AND tipo_caso='Solicitudes'" if "solicitud" in p else "")
                consultas.append((f"Casos {nombre}",
                    f"SELECT tipo_caso, COUNT(*) as total FROM año2025 "
                    f"WHERE municipio='{nombre}' {tipo} GROUP BY tipo_caso"))
                break

        if "municipio" in p and not any(m in p for m in municipios):
            consultas.append(("Por municipio",
                "SELECT municipio, COUNT(*) as total FROM año2025 "
                "GROUP BY municipio ORDER BY total DESC LIMIT 8"))

        if any(w in p for w in ["técnico","tecnico","propietario","quien","quién","atendió"]):
            consultas.append(("Top técnicos",
                "SELECT propietario, COUNT(*) as casos FROM año2025 "
                "GROUP BY propietario ORDER BY casos DESC LIMIT 8"))

        meses = {"enero":"01","febrero":"02","marzo":"03","abril":"04",
                 "mayo":"05","junio":"06","julio":"07","agosto":"08",
                 "septiembre":"09","octubre":"10","noviembre":"11","diciembre":"12"}
        for mes_nom, mes_num in meses.items():
            if mes_nom in p:
                consultas.append((f"Casos {mes_nom.capitalize()}",
                    f"SELECT tipo_caso, COUNT(*) as total FROM año2025 "
                    f"WHERE strftime('%m',creado_el)='{mes_num}' GROUP BY tipo_caso"))
                break

        if any(w in p for w in ["mes","meses","mensual"]) and not any(m in p for m in meses):
            consultas.append(("Mensual",
                """SELECT CASE strftime('%m',creado_el)
                   WHEN '01' THEN 'Ene' WHEN '02' THEN 'Feb' WHEN '03' THEN 'Mar'
                   WHEN '04' THEN 'Abr' WHEN '05' THEN 'May' WHEN '06' THEN 'Jun'
                   WHEN '07' THEN 'Jul' WHEN '08' THEN 'Ago' WHEN '09' THEN 'Sep'
                   WHEN '10' THEN 'Oct' WHEN '11' THEN 'Nov' WHEN '12' THEN 'Dic'
                   END as mes, COUNT(*) as total
                   FROM año2025 GROUP BY strftime('%m',creado_el)
                   ORDER BY strftime('%m',creado_el)"""))

        if any(w in p for w in ["servicio","servicios","categoria"]):
            consultas.append(("Por servicio",
                "SELECT servicio, COUNT(*) as total FROM año2025 "
                "GROUP BY servicio ORDER BY total DESC LIMIT 8"))

        # Búsqueda por hardware o periférico específico
        hardware_lista = [
            "mouse","teclado","monitor","impresora","scanner","escaner",
            "ups","diadema","camara","disco","memoria","cable",
            "garantia","garantías","garantias","equipo","computador",
            "laptop","portatil","portátil","telefono","teléfono"
        ]
        for hw in hardware_lista:
            if hw in p:
                consultas.append((f"Casos '{hw}'",
                    f"SELECT municipio, COUNT(*) as total FROM año2025 "
                    f"WHERE LOWER(servicio) LIKE '%{hw}%' "
                    f"OR LOWER(descripcion) LIKE '%{hw}%' "
                    f"GROUP BY municipio ORDER BY total DESC LIMIT 8"))
                break

        if any(w in p for w in ["ans","sla","cumpl","atención","atencion"]):
            consultas.append(("ANS Atención",
                'SELECT "¿cumplió_ans_de_atención?", COUNT(*) as total '
                'FROM año2025 GROUP BY "¿cumplió_ans_de_atención?"'))
            consultas.append(("ANS Solución",
                'SELECT "¿cumplió_ans_de_solución?", COUNT(*) as total '
                'FROM año2025 GROUP BY "¿cumplió_ans_de_solución?"'))

        if any(w in p for w in ["resumen","estadística","estadistica","informe","general"]):
            consultas = [
                ("Tipos","SELECT tipo_caso, COUNT(*) as total FROM año2025 GROUP BY tipo_caso"),
                ("Municipios","SELECT municipio, COUNT(*) as total FROM año2025 GROUP BY municipio ORDER BY total DESC LIMIT 5"),
                ("Técnicos","SELECT propietario, COUNT(*) as casos FROM año2025 GROUP BY propietario ORDER BY casos DESC LIMIT 5"),
            ]

        if any(w in p for w in ["despacho","juzgado"]):
            consultas.append(("Por despacho",
                "SELECT despacho, COUNT(*) as total FROM año2025 "
                "WHERE despacho IS NOT NULL GROUP BY despacho ORDER BY total DESC LIMIT 8"))

        if not consultas:
            consultas.append(("Resumen básico",
                "SELECT tipo_caso, COUNT(*) as total FROM año2025 GROUP BY tipo_caso"))

    return consultas


def ejecutar_sql(nombre_bd: str, consultas: list) -> str:
    """Retorna resultados en texto plano (no tablas Markdown) para ahorrar tokens."""
    config = BASES_DE_DATOS[nombre_bd]
    try:
        conn   = sqlite3.connect(config["ruta"], check_same_thread=False)
        cursor = conn.cursor()
        res    = f"[DATOS BD: {config['descripcion']}]\n"
        for desc, sql in consultas:
            try:
                cursor.execute(sql)
                cols = [d[0] for d in cursor.description]
                rows = cursor.fetchall()
                if not rows:
                    continue
                res += f"{desc}: "
                # Formato compacto: "col1=val1, col2=val2 | col1=val1..."
                lineas = []
                for row in rows[:8]:   # máximo 8 filas
                    lineas.append(", ".join(
                        f"{cols[i]}={row[i]}" for i in range(len(cols))
                        if row[i] is not None
                    ))
                res += " | ".join(lineas) + "\n"
            except Exception as e:
                res += f"[Error {desc}: {e}]\n"
        conn.close()
        return res
    except Exception as e:
        return f"[Error BD: {e}]\n"


def extraer_fragmento(nombre_doc: str, pregunta: str, max_chars: int = 800) -> str:
    """Extrae el fragmento más relevante. Máximo 800 chars para preservar tokens."""
    with documentos_lock:
        doc = documentos_cargados.get(nombre_doc)
    if not doc:
        return ""

    palabras        = set(re.findall(r'\b[a-záéíóúüñ]{4,}\b', pregunta.lower()))
    pregunta_lower  = pregunta.lower().replace('?','').replace('¿','').strip()
    parrafos        = re.split(r'\n{1,}', doc["contenido"])

    scored = []
    for i, par in enumerate(parrafos):
        par_lower = par.lower()
        score     = sum(1 for p in palabras if p in par_lower)
        if par.strip().startswith('#') and score > 0:
            score += 5
        if pregunta_lower in par_lower:
            score += 10
        if score > 0:
            scored.append((score, i, par))

    scored.sort(reverse=True)

    fragmentos, total, indices = [], 0, set()
    for _, idx, par in scored[:2]:
        for j in range(idx, min(idx + 5, len(parrafos))):
            if j not in indices and total + len(parrafos[j]) <= max_chars:
                fragmentos.append(parrafos[j])
                indices.add(j)
                total += len(parrafos[j])

    if not fragmentos:
        fragmentos = [doc["contenido"][:max_chars]]

    nombre_limpio = os.path.splitext(nombre_doc)[0].replace("_", " ").upper()
    return f"[DOC: {nombre_limpio}]\n" + "\n".join(fragmentos) + "\n"

# ================================================================
#  OLLAMA — timeout duro + semáforo siempre liberado
# ================================================================

def llamar_ollama(ollama_messages: list) -> list:
    adquirido = ollama_semaforo.acquire(timeout=30)
    if not adquirido:
        return ["COLA_LLENA"]
    try:
        resp = requests.post(
            f"{OLLAMA_URL}/v1/chat/completions",
            json={
                "model":    MODEL,
                "messages": ollama_messages,
                "stream":   True,
                "options":  {
                    "temperature": 0.0,
                    "num_predict": 120,
                    "num_ctx":     2048,   # ← clave: evita 500 por overflow
                    "stop": ["\n\n\n", "Espero", "Es importante",
                             "Cabe destacar", "En resumen", "Además"]
                }
            },
            stream=True,
            timeout=(TIMEOUT_CONEXION, TIMEOUT_RESPUESTA)
        )
        if resp.status_code != 200:
            return [f"ERROR_HTTP_{resp.status_code}"]
        chunks = []
        for line in resp.iter_lines():
            if line:
                chunks.append(line.decode("utf-8"))
        return chunks
    except requests.exceptions.ConnectTimeout:
        with ollama_lock:
            ollama_estado["disponible"] = False
        return ["TIMEOUT_CONEXION"]
    except requests.exceptions.ReadTimeout:
        return ["TIMEOUT_RESPUESTA"]
    except requests.exceptions.ConnectionError:
        with ollama_lock:
            ollama_estado["disponible"] = False
        return ["OLLAMA_CAIDO"]
    except Exception as e:
        return [f"ERROR:{e}"]
    finally:
        ollama_semaforo.release()

# ================================================================
#  ENDPOINT PRINCIPAL
# ================================================================

@app.route("/siaa/chat", methods=["POST"])
def chat():
    inc_activos()
    try:
        data     = request.get_json()
        messages = data.get("messages", [])
        if not messages:
            dec_activos()
            return Response("Sin mensajes.", status=400)

        with ollama_lock:
            disponible = ollama_estado["disponible"]
        if not disponible:
            disponible = verificar_ollama()
        if not disponible:
            dec_activos()
            return Response(
                'data: {"choices":[{"delta":{"content":"Servidor IA no disponible. Intente en unos minutos."}}]}\ndata: [DONE]\n',
                content_type="text/event-stream"
            )

        ultima_pregunta = next(
            (m["content"] for m in reversed(messages) if m.get("role") == "user"), ""
        )

        # Contexto
        fuentes  = detectar_fuentes(ultima_pregunta)
        contexto = ""
        for nombre_bd in fuentes["bases_de_datos"]:
            consultas = generar_consultas_sql(ultima_pregunta, nombre_bd)
            contexto += ejecutar_sql(nombre_bd, consultas)
        for nombre_doc in fuentes["documentos"]:
            contexto += extraer_fragmento(nombre_doc, ultima_pregunta)

        # Mensajes para Ollama
        ollama_msgs = [{"role": "system", "content": SYSTEM_BASE}]
        if contexto.strip():
            ollama_msgs.append({"role": "system", "content": contexto})
        for msg in messages[-6:]:   # solo últimos 3 turnos
            if msg.get("role") == "user":
                ollama_msgs.append({
                    "role":    "user",
                    "content": msg["content"] + "\n[Máximo 3 líneas]"
                })
            elif msg.get("role") == "assistant":
                ollama_msgs.append(msg)

        def generate():
            try:
                chunks = llamar_ollama(ollama_msgs)
                if not chunks:
                    yield 'data: {"choices":[{"delta":{"content":"Sin respuesta."}}]}\n'
                    return
                errores = {
                    "COLA_LLENA":        "Sistema ocupado. Intente en 30 segundos.",
                    "TIMEOUT_CONEXION":  "IA no responde. Intente de nuevo.",
                    "TIMEOUT_RESPUESTA": "Consulta muy lenta. Intente de nuevo.",
                    "OLLAMA_CAIDO":      "Servidor IA reiniciándose. Espere 1 minuto.",
                }
                if chunks[0] in errores:
                    msg = errores[chunks[0]]
                    yield f'data: {{"choices":[{{"delta":{{"content":"{msg}"}}}}]}}\n'
                    return
                if chunks[0].startswith("ERROR"):
                    yield 'data: {"choices":[{"delta":{"content":"Error interno."}}]}\n'
                    return
                for line in chunks:
                    yield line + "\n"
            finally:
                dec_activos()

        return Response(
            stream_with_context(generate()),
            content_type="text/event-stream",
            headers={"X-Accel-Buffering": "no", "Cache-Control": "no-cache"}
        )
    except Exception as e:
        dec_activos()
        return jsonify({"error": str(e)}), 500

# ================================================================
#  ENDPOINTS ADMIN
# ================================================================

@app.route("/siaa/status", methods=["GET"])
def status():
    bd_status = {}
    for nombre, config in BASES_DE_DATOS.items():
        try:
            conn   = sqlite3.connect(config["ruta"], check_same_thread=False)
            cursor = conn.cursor()
            cursor.execute("SELECT name FROM sqlite_master WHERE type='table' LIMIT 1")
            tabla  = cursor.fetchone()
            total  = 0
            if tabla:
                cursor.execute(f"SELECT COUNT(*) FROM \"{tabla[0]}\"")
                total = cursor.fetchone()[0]
            conn.close()
            bd_status[nombre] = {"ok": True, "registros": total}
        except Exception as e:
            bd_status[nombre] = {"ok": False, "error": str(e)}
    with ollama_lock:
        ol_ok = ollama_estado["disponible"]
        fallos = ollama_estado["fallos"]
    return jsonify({
        "estado": "ok" if ol_ok else "error",
        "version": "1.4.0",
        "ollama": ol_ok,
        "ollama_fallos": fallos,
        "usuarios_activos": usuarios_activos,
        "total_atendidos": total_atendidos,
        "bases_datos": bd_status,
        "documentos": list(documentos_cargados.keys()),
        "db": all(v["ok"] for v in bd_status.values()),
        "db_casos": bd_status.get("casos_2025", {}).get("registros", 0)
    })

@app.route("/siaa/recargar", methods=["GET"])
def recargar():
    cargar_documentos()
    return jsonify({"recargado": True, "documentos": list(documentos_cargados.keys())})

