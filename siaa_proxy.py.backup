"""
SIAA - Servidor Proxy Inteligente v5.0
=======================================
Versión: 1.4.0
Cambios vs v4:
  - num_ctx 1024 → 2048 (elimina 500 por overflow de contexto)
  - SQL: formato texto plano en lugar de tablas Markdown (ahorra 40% tokens)
  - SQL: máximo 8 filas por consulta (antes 20)
  - Fragmento .md: 800 chars, solo párrafo exacto más siguiente (antes 1800)
  - System prompt compacto (menos tokens fijos)
  - Enrutamiento de 2 niveles con DOCUMENTOS_PALABRAS_CLAVE

Instalación: pip install flask flask-cors requests waitress
"""

import sqlite3
import os
import re
import glob
import threading
import time
import requests
from flask import Flask, request, Response, stream_with_context, jsonify
from flask_cors import CORS

app = Flask(__name__)
CORS(app)

# ================================================================
